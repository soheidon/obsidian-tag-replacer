{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ObsidianTagReplacer",
  "version": "0.1.0",
  "identifier": "com.soheidon.obsidian-tag-replacer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Obsidian Tag Replacer",
        "width": 1100,
        "height": 680,
        "minWidth": 900,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Japanese"]
      }
    }
  }
}
